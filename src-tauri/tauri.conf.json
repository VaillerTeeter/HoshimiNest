{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HoshimiNest",
  "version": "1.0.0",
  "identifier": "HoshimiNest",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1520",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HoshimiNest",
        "width": 1360,
        "height": 820,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src ipc: http://ipc.localhost https://api.bgm.tv; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "externalBin": ["binaries/aria2c", "binaries/mkvmerge"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
