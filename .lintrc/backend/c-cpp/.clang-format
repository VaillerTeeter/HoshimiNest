# clang-format 配置文件 — 适用于 C 源代码
---
Language:        Cpp
BasedOnStyle:    LLVM

# 缩进
IndentWidth:             4
TabWidth:                4
UseTab:                  Never
IndentCaseLabels:        true
IndentCaseBlocks:        false
ContinuationIndentWidth: 4

# 行宽
ColumnLimit: 100

# 大括号风格（Allman：大括号独占一行）
BreakBeforeBraces: Allman

# 禁止短代码合并为单行
AllowShortBlocksOnASingleLine:     Never
AllowShortFunctionsOnASingleLine:  None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine:      false
AllowShortCaseLabelsOnASingleLine: false
AllowShortEnumsOnASingleLine:      false

# 参数/实参换行（不允许混合打包）
BinPackArguments:  false
BinPackParameters: false
AllowAllArgumentsOnNextLine:  false
AllowAllParametersOfDeclarationOnNextLine: false

# 对齐
AlignConsecutiveAssignments:
  Enabled:        true
  AcrossEmptyLines: false
  AcrossComments:   false
AlignConsecutiveMacros:
  Enabled:          true
  AcrossEmptyLines: true
  AcrossComments:   true
AlignConsecutiveDeclarations:
  Enabled:          false
AlignEscapedNewlines:    Right
AlignOperands:           Align
AlignTrailingComments:
  Kind:    Always
  OverEmptyLines: 1

# 指针和引用对齐（右侧，紧贴变量名）
PointerAlignment:   Right
ReferenceAlignment: Right

# 换行规则
BreakBeforeTernaryOperators: true
BreakStringLiterals:         true
BreakBeforeBinaryOperators:  None

# include 排序
SortIncludes:     CaseSensitive
IncludeBlocks:    Regroup
IncludeCategories:
  # 系统头文件 <...>
  - Regex:           '^<.+>'
    Priority:        2
  # 本地头文件 "..."
  - Regex:           '^".+"'
    Priority:        1

# 空格规则
SpaceAfterCStyleCast:           false
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens:              ControlStatements
SpaceInEmptyBlock:              false
SpaceInEmptyParentheses:        false
SpacesBeforeTrailingComments:   2
SpacesInParentheses:            false
SpacesInSquareBrackets:         false
SpacesInCStyleCastParentheses:  false
SpaceAroundPointerQualifiers:   Default

# 空行控制
MaxEmptyLinesToKeep:              1
KeepEmptyLinesAtTheStartOfBlocks: false

# 注释重排
ReflowComments: true

# 宏定义
MacroBlockBegin: ""
MacroBlockEnd:   ""

# C++ 特有设置
# 访问修饰符（public / private / protected）相对类体的偏移量（顶格对齐）
AccessModifierOffset:            -4
# 命名空间内容：不额外缩进
NamespaceIndentation:            None
# 禁止多个嵌套命名空间折叠为一行（namespace a { namespace b { → 展开）
CompactNamespaces:               false
# 自动在命名空间右括号后补充注释（} // namespace foo）
FixNamespaceComments:            true
# 构造函数初始化列表：每个初始化器单独一行
PackConstructorInitializers:     Never
# 构造函数初始化列表冒号：在冒号前换行
BreakConstructorInitializers:    BeforeColon
# 继承列表冒号：在冒号前换行
BreakInheritanceList:            BeforeColon
# 对 using 声明自动排序（类似 include 排序）
SortUsingDeclarations:           true
# C++11 统一初始化语法 {} 前不加空格
SpaceBeforeCpp11BracedList:      false
# 使用 C++11 统一初始化风格（内部无多余空格）
Cpp11BracedListStyle:            true
# 模板声明强制换行（template<...> 独占一行）
AlwaysBreakTemplateDeclarations: Yes
# Lambda 主体缩进：与捕获列表签名对齐
LambdaBodyIndentation:           Signature
# 允许短 Lambda 内联（仅作内联函数参数时可单行）
AllowShortLambdasOnASingleLine:  Inline
