# clang-tidy 配置文件 — 适用于 C++ 源代码
---
# 启用的检查类别（逗号分隔，- 前缀表示禁用）
Checks: >-
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  hicpp-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cert-dcl37-c,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-vararg,
  -hicpp-no-array-decay,
  -hicpp-vararg,
  -misc-no-recursion,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers

# 将所有警告视为错误
WarningsAsErrors: "*"

# 对所有头文件也执行检查（匹配当前目录下的所有 .hpp / .hh / .hxx）
HeaderFilterRegex: ".*"

# 格式化风格引用 .clang-format 文件
FormatStyle: file

# 命名规范检查选项
CheckOptions:
  # 函数名：snake_case
  - key:   readability-identifier-naming.FunctionCase
    value: lower_case
  # 方法名（类成员函数）：snake_case
  - key:   readability-identifier-naming.MethodCase
    value: lower_case
  # 普通变量：snake_case
  - key:   readability-identifier-naming.VariableCase
    value: lower_case
  # 函数参数：snake_case
  - key:   readability-identifier-naming.ParameterCase
    value: lower_case
  # 局部变量：snake_case
  - key:   readability-identifier-naming.LocalVariableCase
    value: lower_case
  # 全局变量：snake_case，加 g_ 前缀
  - key:   readability-identifier-naming.GlobalVariableCase
    value: lower_case
  - key:   readability-identifier-naming.GlobalVariablePrefix
    value: g_
  # 成员变量：snake_case，加 m_ 前缀（区别于局部变量）
  - key:   readability-identifier-naming.MemberCase
    value: lower_case
  - key:   readability-identifier-naming.MemberPrefix
    value: m_
  # 静态成员变量：snake_case，加 s_ 前缀
  - key:   readability-identifier-naming.StaticMemberCase
    value: lower_case
  - key:   readability-identifier-naming.StaticMemberPrefix
    value: s_
  # 类名：PascalCase（UpperCamelCase）
  - key:   readability-identifier-naming.ClassCase
    value: CamelCase
  # struct 名：PascalCase（C++ struct 常作类使用）
  - key:   readability-identifier-naming.StructCase
    value: CamelCase
  # 命名空间：全小写，可含下划线
  - key:   readability-identifier-naming.NamespaceCase
    value: lower_case
  # 模板类型参数：PascalCase
  - key:   readability-identifier-naming.TemplateParameterCase
    value: CamelCase
  # 宏定义：UPPER_CASE
  - key:   readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  # 枚举常量：UPPER_CASE
  - key:   readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  # 枚举名（enum class）：PascalCase
  - key:   readability-identifier-naming.EnumCase
    value: CamelCase
  # 类型别名（using）：PascalCase
  - key:   readability-identifier-naming.TypeAliasCase
    value: CamelCase
  # typedef 类型：snake_case + _t 后缀（兼容 C 风格）
  - key:   readability-identifier-naming.TypedefCase
    value: lower_case
  - key:   readability-identifier-naming.TypedefSuffix
    value: _t
