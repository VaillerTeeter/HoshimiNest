<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle 配置 — 基于 Google Java Style Guide 定制
  参考：https://checkstyle.org/google_style.html
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- ── 文件级检查 ──────────────────────────────────── -->

  <!-- 文件末尾必须有换行符 -->
  <module name="NewlineAtEndOfFile"/>

  <!-- 文件长度上限：800 行 -->
  <module name="FileLength">
    <property name="max" value="800"/>
  </module>

  <!-- 禁止制表符（Tab） -->
  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
  </module>

  <!-- 行尾不能有多余空格 -->
  <module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="message" value="行尾不允许有多余空格"/>
  </module>

  <!-- 行长度：最多 100 字符（文件级检查，必须在 Checker 下） -->
  <module name="LineLength">
    <property name="max" value="100"/>
    <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
  </module>

  <!-- ── 树遍历检查（Token-based） ──────────────────── -->
  <module name="TreeWalker">

    <!-- ===== 命名规范 ===== -->

    <!-- 包名：全小写，可含点和数字 -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>

    <!-- 类名 / 接口名：PascalCase -->
    <module name="TypeName"/>

    <!-- 方法名：lowerCamelCase -->
    <module name="MethodName"/>

    <!-- 局部变量名：lowerCamelCase，允许单字符（i/j/k/e/x/y/z） -->
    <module name="LocalVariableName">
      <property name="format" value="^[a-z]([a-z0-9][a-zA-Z0-9]*)?$"/>
    </module>

    <!-- 局部 final 变量（try-with-resources 等）：lowerCamelCase -->
    <module name="LocalFinalVariableName"/>

    <!-- 成员变量：lowerCamelCase -->
    <module name="MemberName"/>

    <!-- static 成员变量：lowerCamelCase（非常量） -->
    <module name="StaticVariableName"/>

    <!-- 常量（static final）：UPPER_CASE -->
    <module name="ConstantName"/>

    <!-- 参数名：lowerCamelCase -->
    <module name="ParameterName">
      <property name="format" value="^[a-z]([a-z0-9][a-zA-Z0-9]*)?$"/>
    </module>

    <!-- 泛型类型参数：单个大写字母，或大写字母后跟数字 -->
    <module name="ClassTypeParameterName">
      <property name="format" value="^[A-Z][0-9]?$"/>
    </module>
    <module name="MethodTypeParameterName">
      <property name="format" value="^[A-Z][0-9]?$"/>
    </module>

    <!-- catch 块参数：lowerCamelCase 或单字符 e -->
    <module name="CatchParameterName">
      <property name="format" value="^[a-z]([a-z0-9][a-zA-Z0-9]*)?$"/>
    </module>

    <!-- ===== Javadoc ===== -->

    <!-- public 类必须有 Javadoc -->
    <module name="JavadocType">
      <property name="scope" value="public"/>
    </module>

    <!-- public / protected 方法必须有 Javadoc -->
    <module name="JavadocMethod">
      <property name="accessModifiers" value="public, protected"/>
      <property name="allowMissingParamTags" value="false"/>
      <property name="allowMissingReturnTag" value="false"/>
    </module>

    <!-- public / protected 变量必须有 Javadoc -->
    <module name="JavadocVariable">
      <property name="scope" value="protected"/>
    </module>

    <!-- Javadoc 样式：摘要句必须以句点结尾 -->
    <module name="JavadocStyle">
      <property name="checkFirstSentence" value="true"/>
      <property name="endOfSentenceFormat" value="([.?!][ \t\n\r\f&lt;])|([.?!]$)"/>
    </module>

    <!-- ===== Import ===== -->

    <!-- 禁止通配符 import -->
    <module name="AvoidStarImport"/>

    <!-- 禁止冗余 import（重复或 java.lang） -->
    <module name="RedundantImport"/>

    <!-- 禁止未使用的 import -->
    <module name="UnusedImports"/>

    <!-- import 顺序：static import 在最后，各组之间空行 -->
    <module name="ImportOrder">
      <property name="groups" value="java,javax,org,com"/>
      <property name="ordered" value="true"/>
      <property name="separated" value="true"/>
      <property name="option" value="bottom"/>
      <property name="sortStaticImportsAlphabetically" value="true"/>
    </module>

    <!-- ===== 代码尺寸 ===== -->

    <!-- 方法长度：最多 60 行（不含空行和注释） -->
    <module name="MethodLength">
      <property name="max" value="60"/>
      <property name="countEmpty" value="false"/>
    </module>

    <!-- 方法参数数：最多 5 个 -->
    <module name="ParameterNumber">
      <property name="max" value="5"/>
    </module>

    <!-- 匿名类长度：最多 20 行 -->
    <module name="AnonInnerLength">
      <property name="max" value="20"/>
    </module>

    <!-- ===== 大括号与空白 ===== -->

    <!-- 左大括号位置：行尾（K&R/Allman 之外的 Otbs 风格） -->
    <module name="LeftCurly"/>

    <!-- 右大括号位置 -->
    <module name="RightCurly"/>

    <!-- if / else / for / while / do 必须用大括号 -->
    <module name="NeedBraces"/>

    <!-- 空块必须包含注释（如 catch(Exception e) {}） -->
    <module name="EmptyBlock">
      <property name="option" value="text"/>
    </module>

    <!-- 操作符换行：换行在操作符前 -->
    <module name="OperatorWrap"/>

    <!-- 方法调用的点号换行：点号在下一行开头 -->
    <module name="SeparatorWrap">
      <property name="id" value="SeparatorWrapDot"/>
      <property name="tokens" value="DOT"/>
      <property name="option" value="nl"/>
    </module>

    <!-- 逗号换行：逗号在末尾 -->
    <module name="SeparatorWrap">
      <property name="id" value="SeparatorWrapComma"/>
      <property name="tokens" value="COMMA"/>
      <property name="option" value="EOL"/>
    </module>

    <!-- 空格检查 -->
    <module name="WhitespaceAround">
      <property name="allowEmptyConstructors" value="true"/>
      <property name="allowEmptyLambdas" value="true"/>
      <property name="allowEmptyMethods" value="true"/>
      <property name="allowEmptyTypes" value="true"/>
      <property name="allowEmptyLoops" value="true"/>
    </module>
    <module name="WhitespaceAfter"/>
    <module name="NoWhitespaceBefore"/>
    <module name="NoWhitespaceAfter"/>
    <module name="GenericWhitespace"/>
    <module name="MethodParamPad"/>
    <module name="ParenPad"/>
    <module name="TypecastParenPad"/>

    <!-- 缩进：4 空格，续行 8 空格 -->
    <module name="Indentation">
      <property name="basicOffset" value="4"/>
      <property name="braceAdjustment" value="0"/>
      <property name="caseIndent" value="4"/>
      <property name="throwsIndent" value="8"/>
      <property name="lineWrappingIndentation" value="8"/>
      <property name="arrayInitIndent" value="4"/>
    </module>

    <!-- ===== 编码规范 ===== -->

    <!-- 修饰符顺序：public protected private abstract default static ... -->
    <module name="ModifierOrder"/>

    <!-- 多余修饰符（如接口中的 public abstract） -->
    <module name="RedundantModifier"/>

    <!-- switch 必须有 default 分支 -->
    <module name="DefaultComesLast"/>
    <module name="MissingSwitchDefault"/>

    <!-- switch case 之间不允许直通（fall-through），需加 // fall through 注释 -->
    <module name="FallThrough"/>

    <!-- long 字面量使用 L 而非 l -->
    <module name="UpperEll"/>

    <!-- 数组声明风格：int[] arr 而非 int arr[] -->
    <module name="ArrayTypeStyle"/>

    <!-- 不允许使用 == 比较字符串 -->
    <module name="StringLiteralEquality"/>

    <!-- 不允许多次赋值：a = b = c -->
    <module name="MultipleVariableDeclarations"/>

    <!-- 每行只有一条语句 -->
    <module name="OneStatementPerLine"/>

    <!-- 不允许空语句（孤立的分号） -->
    <module name="EmptyStatement"/>

    <!-- 不允许在 equals() 中使用 == -->
    <module name="CovariantEquals"/>

    <!-- 重写 equals() 必须同时重写 hashCode() -->
    <module name="EqualsHashCode"/>

    <!-- clone() 必须调用 super.clone() -->
    <module name="SuperClone"/>

    <!-- finalize() 必须调用 super.finalize() -->
    <module name="SuperFinalize"/>

    <!-- 不允许内联条件（三元运算符嵌套使用除外）：禁止 if (a ? b : c) -->
    <!-- 已注释，因三元运算符在表达式中是正常用法
    <module name="AvoidInlineConditionals"/> -->

    <!-- 禁止魔法数字（仅 -1, 0, 1 除外） -->
    <module name="MagicNumber">
      <property name="ignoreNumbers" value="-1, 0, 1"/>
      <property name="ignoreAnnotation" value="true"/>
      <property name="ignoreHashCodeMethod" value="true"/>
    </module>

    <!-- 简化布尔表达式：禁止 b == true、b != false 等 -->
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>

    <!-- 禁止不必要的括号 -->
    <module name="UnnecessaryParentheses"/>

    <!-- 禁止使用过时的 API -->
    <module name="IllegalType">
      <property name="illegalClassNames" value="
        java.util.Hashtable,
        java.util.Vector,
        java.util.Stack,
        java.util.StringTokenizer,
        java.util.Date,
        java.sql.Date,
        java.util.Calendar"/>
    </module>

    <!-- ===== 设计 ===== -->

    <!-- 工具类（所有成员均为 static）必须有私有构造器 -->
    <module name="HideUtilityClassConstructor"/>

    <!-- 接口不应只用于定义常量（Constant Interface 反模式） -->
    <module name="InterfaceIsType"/>

    <!-- 类的外联耗类数量：单类引用别类不超过 20 个 -->
    <module name="ClassFanOutComplexity">
      <property name="max" value="20"/>
    </module>

    <!-- 方法声明 throws 的异常类不超过 3 个 -->
    <module name="ThrowsCount">
      <property name="max" value="3"/>
      <property name="ignorePrivateMethods" value="false"/>
    </module>

    <!-- 布尔表达式复杂度：&&/|| 操作符不超过 3 个 -->
    <module name="BooleanExpressionComplexity">
      <property name="max" value="3"/>
    </module>

    <!-- 圈复杂度上限：10（与 PMD/detekt 对齐） -->
    <module name="CyclomaticComplexity">
      <property name="max" value="10"/>
    </module>

    <!-- 可见性控制：所有成员变量必须为 private（不允许 protected 字段） -->
    <module name="VisibilityModifier">
      <property name="packageAllowed" value="false"/>
      <property name="protectedAllowed" value="false"/>
    </module>

    <!-- ===== 杂项 ===== -->

    <!-- TODO 注释格式化（允许但统一格式） -->
    <module name="TodoComment">
      <property name="format" value="(TODO|FIXME|HACK|XXX):"/>
    </module>

    <!-- 禁止在代码中出现 System.out.println -->
    <module name="RegexpSinglelineJava">
      <property name="format" value="System\.out\.print"/>
      <property name="message" value="不允许使用 System.out.print，请使用日志框架"/>
      <property name="ignoreComments" value="true"/>
    </module>

    <!-- 禁止 printStackTrace() -->
    <module name="RegexpSinglelineJava">
      <property name="format" value="\.printStackTrace\(\)"/>
      <property name="message" value="不允许使用 printStackTrace()，请使用日志框架"/>
      <property name="ignoreComments" value="true"/>
    </module>

  </module>
</module>
