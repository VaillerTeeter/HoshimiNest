<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs 排除过滤器
  语法参考：https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter
  xmlns="https://github.com/spotbugs/filter/3.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                    https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!-- ══════════════════════════════════════════════════
      测试代码宽限
  ══════════════════════════════════════════════════ -->

  <!-- 测试类允许使用 assert（EI_EXPOSE_REP2 等测试常见模式） -->
  <Match>
    <Class name="~.*Test(s)?$"/>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
  </Match>

  <!-- 测试基类 / 辅助类 -->
  <Match>
    <Class name="~.*TestHelper$"/>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
  </Match>

  <!-- ══════════════════════════════════════════════════
      框架 / 生成代码宽限
  ══════════════════════════════════════════════════ -->

  <!-- Lombok 生成的 equals/hashCode 方法 -->
  <Match>
    <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
    <Source name="~.*\.java$"/>
  </Match>

  <!-- Spring / JPA 实体类：序列化 UID 不强制 -->
  <Match>
    <Bug pattern="SE_NO_SERIALVERSIONUID"/>
    <Class name="~.*Entity$|~.*Dto$|~.*VO$|~.*Request$|~.*Response$"/>
  </Match>

  <!-- ══════════════════════════════════════════════════
      合理的误报排除
  ══════════════════════════════════════════════════ -->

  <!-- 返回内部可变数组（框架 API 常见，调用者不应修改） -->
  <!-- 若项目确实需要保护，请删除此条目 -->
  <!-- <Match>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match> -->

  <!-- ══════════════════════════════════════════════════
      不适用于项目的规则
  ══════════════════════════════════════════════════ -->

  <!-- 允许 null 返回（显式的 API 契约） -->
  <!-- <Match>
    <Bug pattern="NP_NULL_ON_SOME_PATH"/>
  </Match> -->

</FindBugsFilter>
