<?xml version="1.0"?>
<ruleset name="Custom PMD Rules"
  xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                    https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

  <description>
    自定义 PMD 规则集 — 覆盖 Best Practices / Code Style /
    Design / Error Prone / Performance / Security /
    Multithreading / Documentation 八大类别
  </description>

  <!-- ══════════════════════════════════════════════════
      Best Practices（最佳实践）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/bestpractices.xml">
    <!-- 允许使用具体集合实现类（ArrayList、HashMap 等）而非接口类型；
      LooseCoupling 即"松散耦合": 建议用 List/Map 等接口声明变量。
      如需强制接口类型，请移除此排除项 -->
    <exclude name="LooseCoupling"/>
  </rule>

  <!-- ══════════════════════════════════════════════════
      Code Style（代码风格）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/codestyle.xml">
    <!-- 允许短变量名（i/j/k 等循环变量） -->
    <exclude name="ShortVariable"/>
    <!-- 允许长变量名（业务代码描述性命名） -->
    <exclude name="LongVariable"/>
  </rule>

  <!-- ══════════════════════════════════════════════════
      Design（设计）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/design.xml"/>

  <!-- 自定义复杂度限制 -->
  <rule ref="category/java/design.xml/CyclomaticComplexity">
    <properties>
      <!-- 圈复杂度上限：方法 10，类 40（极严格） -->
      <property name="methodReportLevel" value="10"/>
      <property name="classReportLevel" value="40"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/NPathComplexity">
    <properties>
      <!-- NPath 复杂度上限（极严格） -->
      <property name="reportLevel" value="100"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/TooManyMethods">
    <properties>
      <!-- 单类最多方法数（极严格） -->
      <property name="maxmethods" value="15"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/TooManyFields">
    <properties>
      <!-- 单类最多字段数（极严格） -->
      <property name="maxfields" value="10"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/ExcessiveClassLength">
    <properties>
      <property name="minimum" value="400"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/ExcessiveMethodLength">
    <properties>
      <property name="minimum" value="60"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/ExcessiveParameterList">
    <properties>
      <property name="minimum" value="5"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/ExcessiveImports">
    <properties>
      <!-- 单类 import 数量上限（极严格） -->
      <property name="minimum" value="20"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml/TooManyPublicMethods">
    <properties>
      <!-- 单类最多 public 方法数（极严格） -->
      <property name="maxmethods" value="12"/>
    </properties>
  </rule>
  <!-- ══════════════════════════════════════════════════
      Error Prone（易错模式）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/errorprone.xml">
    <!-- 允许在条件中赋值（如 while ((line = reader.readLine()) != null)） -->
    <exclude name="AssignmentInOperand"/>
    <!-- 允许 null 赋值给返回值（框架中合理） -->
    <exclude name="ReturnEmptyCollectionRatherThanNull"/>
  </rule>

  <!-- ══════════════════════════════════════════════════
      Performance（性能）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/performance.xml"/>

  <!-- ══════════════════════════════════════════════════
      Security（安全）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/security.xml"/>

  <!-- ══════════════════════════════════════════════════
      Multithreading（多线程）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/multithreading.xml"/>

  <!-- ══════════════════════════════════════════════════
      Documentation（文档）
  ══════════════════════════════════════════════════ -->
  <rule ref="category/java/documentation.xml">
    <properties>
      <property name="violationSuppressXPath"
      value="//ClassOrInterfaceDeclaration[@Public='false']"/>
    </properties>
  </rule>

</ruleset>
