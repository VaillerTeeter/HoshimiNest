dotnet_diagnostic.CA5350.severity = error    # 不要使用弱加密算法（MD5/SHA1）
dotnet_diagnostic.CA5351.severity = error    # 不要使用弱加密算法
dotnet_diagnostic.CA5359.severity = error    # 不要禁用证书验证
