parameters:
  # ============================================================
  # 分析级别（0-10，9 = 极严格）
  # ============================================================
  level: 9

  # ============================================================
  # 路径配置
  # ============================================================
  paths:
    - src
    - app
  excludePaths:
    - vendor
    - node_modules
    - tests
    - database/migrations

  # ============================================================
  # Bleeding Edge（启用最新规则，包括未来版本将默认启用的）
  # ============================================================
  bleedingEdge: true

  # ============================================================
  # 类型严格性
  # ============================================================
  # 检查未指定类型的函数参数（适用于 PHP 8.x）
  checkMissingIterableValueType: true
  # 是否允许隐式混合类型
  treatPhpDocTypesAsCertain: true
  # union type 检查
  checkImplicitMixed: true
  # 更严格的 dead code 检测
  reportUnmatchedIgnoredErrors: true
  # 检查声明的返回类型是否比实际返回值更宽
  checkTooWideReturnTypes: true
  # PHPDoc 必须与实际类型匹配
  reportMaybes: true
  # 报告条件语句最后一个条件始终为 true 的情况
  reportAlwaysTrueInLastCondition: true
  # 静态属性必须初始化
  checkUninitializedProperties: true

  # ============================================================
  # 配置文件扩展（Laravel/Symfony 等框架需要 extension 包）
  # ============================================================
  # bootstrapFiles:
  #   - bootstrap/app.php

  # ============================================================
  # 忽略特定错误（使用 regex 匹配）
  # ============================================================
  ignoreErrors:
    # 忽略生成文件
    - path: app/Http/Middleware/TrustProxies.php
      message: "#.*#"
      count: 1

  # ============================================================
  # 并行处理
  # ============================================================
  parallel:
    maximumNumberOfProcesses: 4

  # ============================================================
  # 缓存
  # ============================================================
  tmpDir: .phpstan-cache
