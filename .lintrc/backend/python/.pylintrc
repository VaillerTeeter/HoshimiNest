[MASTER]
# 并行分析的进程数（0 = 自动）
jobs = 0

# 失败阈值：要求满分通过
fail-under = 10.0

# 忽略的目录
ignore-paths =
    .git,
    .github,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    .mypy_cache,
    .pytest_cache,
    .tox

[MESSAGES CONTROL]
# 启用所有检查，再按需禁用
enable = all

# 禁用的规则（附说明）
disable =
    # C0114-C0116：缺少模块/类/函数文档字符串（flake8-docstring 已覆盖）
    C0114,
    C0115,
    C0116,
    # R0903：类公共方法少于 2 个（小型数据类常见）
    R0903,
    # W0511：TODO / FIXME 注释（开发期合理）
    W0511,
    # W0212：访问保护成员 _xx（测试代码中合理）
    W0212,
    # C0301：行超长（由 flake8 max-line-length 负责）
    C0301,
    # C0303：行尾空格（由格式化工具负责）
    C0303,
    # C0304：文件末尾缺少换行（由格式化工具负责）
    C0304

[FORMAT]
# 最大行长度
max-line-length = 100

# 缩进：4 空格
indent-string = '    '

# 函数参数之间对齐的最大不一致差异
indent-after-paren = 4

[DESIGN]
# 函数/方法最大参数数
max-args = 5

# 函数最大局部变量数
max-locals = 15

# 函数最大语句数
max-statements = 40

# 函数/方法最大返回点数
max-returns = 3

# 函数/方法最大分支数
max-branches = 10

# 类最大属性数
max-attributes = 10

# 类最大公共方法数
max-public-methods = 15

# 模块最多允许的函数数
max-module-lines = 1000

[SIMILARITIES]
# 重复代码检测最小行数
min-similarity-lines = 6

# 对比时忽略注释
ignore-comments = yes

# 对比时忽略文档字符串
ignore-docstrings = yes

# 对比时忽略 import
ignore-imports = yes

[VARIABLES]
# 允许的单字符变量名（循环计数器、数学变量等）
good-names = i, j, k, n, x, y, z, e, f, _

# 允许以正则匹配的变量名（哑变量）
dummy-variables-rgx = _+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+$)|dummy|^ignored_|^unused_

[NAMING CONVENTIONS]
# 模块名：snake_case
module-rgx = (([a-z_][a-z0-9_]*)|([A-Z][a-zA-Z0-9]+))$

# 常量名：UPPER_CASE
const-rgx = (([A-Z_][A-Z0-9_]*)|(__.*__))$

# 类名：PascalCase
class-rgx = [A-Z][a-zA-Z0-9]+$

# 函数/方法名：snake_case
function-rgx = [a-z_][a-z0-9_]{0,50}$
method-rgx = [a-z_][a-z0-9_]{0,50}$

# 属性/参数/变量名：snake_case（允许 1-30 字符）
attr-rgx = [a-z_][a-z0-9_]{0,30}$
argument-rgx = [a-z_][a-z0-9_]{0,30}$
variable-rgx = [a-z_][a-z0-9_]{0,30}$

# 内联变量（for/with/except 等）
inlinevar-rgx = [A-Za-z_][A-Za-z0-9_]*$

[TYPECHECK]
# 忽略不可分析的模块的 "no-member" 错误
ignored-modules =
    numpy,
    cv2,
    scipy,
    torch,
    tensorflow

# 忽略这些类的成员检查
ignored-classes =
    optparse.Values,
    thread._local,
    _thread._local

[EXCEPTIONS]
# 允许捕获的通用异常类型
overgeneral-exceptions =
    builtins.BaseException,
    builtins.Exception

[IMPORTS]
# 禁止通配符导入
allow-wildcard-with-all = no

# 已知的第三方库（辅助 pylint 区分标准库和第三方）
known-third-party = requests, numpy, pandas, flask, django, pytest

[LOGGING]
# logging 格式化方式（lazy 避免不必要的字符串格式化）
logging-modules = logging
logging-format-style = new

[STRING]
# 检查 % 格式化字符串与参数不匹配
check-quote-consistency = yes
