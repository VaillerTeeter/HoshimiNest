[flake8]
# 最大行长度（与 black/pylint 保持一致）
max-line-length = 100

# 最大函数复杂度（圈复杂度）
max-complexity = 10

# 启用额外插件规则
extend-select =
    # flake8-bugbear：检测常见 bug 模式
    B,
    # flake8-bugbear 严格模式（更激进的规则）
    B9,
    # flake8-comprehensions：列表/字典/集合推导式优化
    C4,
    # flake8-simplify：代码简化建议
    SIM,
    # flake8-pie：多余代码模式
    PIE,
    # flake8-return：return 语句规范
    RET,
    # flake8-raise：raise 语句规范
    RSE,
    # flake8-unused-arguments：未使用的函数参数
    U,
    # pep8-naming：PEP 8 命名规范检查
    N,
    # flake8-annotations：函数注解（类型提示）检查
    ANN,
    # flake8-docstring（pydocstyle）：文档字符串规范
    D,
    # flake8-bandit：安全漏洞扫描（集成 bandit）
    S,
    # flake8-isort：import 排序检查
    I,
    # flake8-eradicate：注释掉的死代码检测
    E8,
    # flake8-builtins：避免覆盖内置名称
    A

# 忽略的规则
extend-ignore =
    # D1xx：缺少文档字符串（脚本 / 测试文件中不强制）
    D100, D101, D102, D103, D104, D105, D107,
    # D203：文档字符串前要求一空行（与 D211 冲突，选 D211）
    D203,
    # D213：多行文档字符串摘要在第二行（与 D212 冲突，选 D212）
    D213,
    # ANN101/ANN102：self/cls 不需要类型注解
    ANN101, ANN102,
    # ANN401：允许使用 Any 类型（底层代码有合理场景）
    ANN401,
    # E501 由 max-line-length 控制，B950 负责实际超长检测
    E501,
    # W503：二元运算符换行（与 W504 冲突，PEP 8 推荐 W504）
    W503,
    # S101：使用 assert（在测试文件中是正常的）
    S101

# 每个文件的忽略配置
per-file-ignores =
    # 测试文件：允许 assert、放宽注解和文档字符串要求
    tests/*:S101,ANN,D
    test_*.py:S101,ANN,D
    *_test.py:S101,ANN,D
    # __init__.py：允许未使用 import（公共 API 重导出）
    __init__.py:F401

# 排除的目录和文件
exclude =
    .git,
    .github,
    __pycache__,
    .venv,
    venv,
    env,
    .env,
    build,
    dist,
    *.egg-info,
    .mypy_cache,
    .pytest_cache,
    .tox,
    node_modules

# isort 兼容配置
application-import-names = src
import-order-style = google

# 统计每类错误数量
statistics = true
count = true
show-source = true
