# Perl::Critic configuration
# See: https://metacpan.org/dist/Perl-Critic/view/lib/Perl/Critic.pm

severity  = 1
theme     = core + pbp + security
force     = 0

[CodeLayout::RequireTidyCode]
perltidy = perltidy -l=120 -i=4 -ci=4 -se -b -bext=/ -nola

[Variables::ProhibitPunctuationVars]
allow = $_ $! $0 $/ $\ $, $" $; $@ $? $|

[Subroutines::ProhibitExcessComplexity]
max_mccabe = 10

[Modules::RequireVersionVar]
severity = 4

[Modules::ProhibitMultiplePackages]
severity = 5

[BuiltinFunctions::ProhibitSleepViaSelect]
severity = 5

[InputOutput::RequireCheckedSyscalls]
functions = :builtins
exclude_functions = print say warn

[RegularExpressions::RequireExtendedFormatting]
minimum_regex_length_to_complain_about = 20

[TestingAndDebugging::RequireUseStrict]
severity = 5

[TestingAndDebugging::RequireUseWarnings]
severity = 5

[ValuesAndExpressions::ProhibitMagicNumbers]
allowed_values = -1 0 1
