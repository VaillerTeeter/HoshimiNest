{
  "root": true,
  "env": {
    "es2022": true,
    "node": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["import", "unicorn", "sonarjs", "security", "promise", "n", "jsdoc"],
  "extends": [
    "eslint:recommended",
    "plugin:import/recommended",
    "plugin:unicorn/recommended",
    "plugin:sonarjs/recommended",
    "plugin:security/recommended-legacy",
    "plugin:promise/recommended",
    "plugin:n/recommended",
    "plugin:jsdoc/recommended"
  ],
  "rules": {
    "no-console": "error",
    "no-debugger": "error",
    "no-alert": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",

    "no-var": "error",
    "prefer-const": "error",
    "prefer-template": "error",
    "prefer-destructuring": ["error", { "array": true, "object": true }],
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "prefer-arrow-callback": "error",
    "prefer-exponentiation-operator": "error",
    "prefer-object-spread": "error",
    "object-shorthand": ["error", "always"],
    "arrow-body-style": ["error", "as-needed"],
    "symbol-description": "error",

    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "curly": ["error", "all"],
    "default-case": "error",
    "default-case-last": "error",
    "guard-for-in": "error",
    "no-caller": "error",
    "no-extend-native": "error",
    "no-extra-bind": "error",
    "no-floating-decimal": "error",
    "no-implicit-globals": "error",
    "no-iterator": "error",
    "no-lone-blocks": "error",
    "no-multi-spaces": "error",
    "no-new-wrappers": "error",
    "no-param-reassign": "error",
    "no-proto": "error",
    "no-return-assign": "error",
    "no-self-compare": "error",
    "no-sequences": "error",
    "no-throw-literal": "error",
    "no-unused-expressions": "error",
    "no-useless-call": "error",
    "no-useless-concat": "error",
    "no-useless-return": "error",
    "no-duplicate-imports": "error",
    "no-template-curly-in-string": "error",
    "no-unreachable-loop": "error",
    "no-promise-executor-return": "error",
    "no-use-before-define": ["error", { "functions": false, "classes": true }],
    "array-callback-return": "error",
    "consistent-return": "error",
    "radix": "error",
    "require-await": "error",
    "yoda": "error",

    "no-shadow": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "caughtErrorsIgnorePattern": "^_" }],

    "camelcase": ["error", { "properties": "always" }],
    "new-cap": "error",
    "no-lonely-if": "error",
    "no-multi-assign": "error",
    "no-nested-ternary": "error",
    "no-unneeded-ternary": "error",
    "operator-assignment": "error",

    "max-params": ["error", 5],
    "max-lines": ["error", { "max": 500, "skipComments": true, "skipBlankLines": true }],
    "max-lines-per-function": [
      "error",
      { "max": 60, "skipComments": true, "skipBlankLines": true }
    ],
    "max-depth": ["error", 3],
    "max-nested-callbacks": ["error", 3],
    "complexity": ["error", 10],

    "unicorn/prevent-abbreviations": "off",
    "unicorn/no-null": "off",
    "unicorn/filename-case": ["error", { "cases": { "kebabCase": true, "camelCase": true } }],
    "unicorn/no-array-for-each": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/prefer-module": "off",

    "jsdoc/require-param-description": "warn",
    "jsdoc/require-returns-description": "warn",
    "jsdoc/require-jsdoc": "off",

    "import/order": [
      "error",
      {
        "groups": ["builtin", "external", "internal", "parent", "sibling", "index"],
        "newlines-between": "always",
        "alphabetize": { "order": "asc" }
      }
    ],
    "import/no-cycle": "error",
    "import/no-self-import": "error",
    "import/no-useless-path-segments": "error",
    "import/no-duplicates": "error",

    "n/no-unsupported-features/es-syntax": "off",
    "n/no-missing-require": "off"
  }
}
