{
  "no-trailing-spaces": "on",
  "no-restricted-patterns": "off",
  "no-files-without-scenarios": "on",
  "no-dupe-scenario-names": "on",
  "no-duplicate-tags": "on",
  "new-line-at-eof": ["on", "yes"],
  "no-empty-file": "on",
  "no-multiple-empty-lines": ["on", 1],
  "indentation": [
    "on",
    {
      "Feature": 0,
      "Background": 2,
      "Scenario": 2,
      "Step": 4,
      "Examples": 4,
      "example": 6,
      "given": 4,
      "when": 4,
      "then": 4,
      "and": 4,
      "but": 4
    }
  ],
  "no-superfluous-tags": "on",
  "no-restricted-tags": "off",
  "no-unused-variables": "on",
  "no-homogeneous-tags": "on",
  "keywords-in-logical-order": "on",
  "required-tags": "off"
}
