[sqlfluff]
# 方言：ansi / mysql / postgres / tsql / bigquery / snowflake / spark / duckdb 等
# 设为 ansi 作为通用基准；项目中按实际数据库修改
dialect = ansi

# 最大行宽
max_line_length = 120

# 缩进宽度（空格数）
indent_unit = space
tab_space_size = 4

# 模板引擎（Jinja2 用于 dbt 项目，noqa 跳过渲染失败）
templater = jinja

# 不处理的文件后缀
large_file_skip_char_limit = 20000

# 输出格式：human / json / yaml / github_annotation
output_line_length = 120

[sqlfluff:indentation]
# 缩进风格
indent_unit = space
tab_space_size = 4
indented_joins = false
indented_using_on = true
template_blocks_indent = true

[sqlfluff:layout:type:comma]
# 逗号放在行尾（trailing comma style）
line_position = trailing

[sqlfluff:rules]
# 允许空格包围的运算符
allow_scalar = true

[sqlfluff:rules:aliasing.table]
# 表别名必须显式使用 AS
aliasing = explicit

[sqlfluff:rules:aliasing.column]
# 列别名必须显式使用 AS
aliasing = explicit

[sqlfluff:rules:aliasing.expression]
# 表达式必须有别名
allow_scalar = false

[sqlfluff:rules:capitalisation.keywords]
# 关键字大写：consistent / upper / lower / capitalise
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
# 标识符大小写：consistent
capitalisation_policy = consistent

[sqlfluff:rules:capitalisation.functions]
# 内置函数大写
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
# null/true/false 大写
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
# 数据类型大写（VARCHAR、INT 等）
extended_capitalisation_policy = upper

[sqlfluff:rules:convention.select_trailing_comma]
# SELECT 列表末尾逗号处理
select_clause_trailing_comma = forbid

[sqlfluff:rules:convention.not_equal]
# 不等于符号统一用 <>（ANSI）或 !=（MySQL 风格）
preferred_not_equal_style = c_style

[sqlfluff:rules:convention.is_null]
# 使用 IS NULL 而非 = NULL
is_null = is

[sqlfluff:rules:references.from]
# 所有列引用在多表查询中必须限定表名
table_sources = consistent

[sqlfluff:rules:structure.subquery]
# 子查询风格：join / from / where
forbid_subquery_in = join
