## chktex configuration
## See: https://www.nongnu.org/chktex/ChkTeX.pdf

## Suppress specific warning numbers
## -n 3:  You should enclose the previous parenthesis with {}
## -n 6:  No italic correction (\/') found
## -n 22: Comment displayed
## -n 30: Multiple spaces in input
## -n 38: You should not use punctuation in front of quotes
WarnFilter {
    3
    6
    22
    30
    38
}

## Set tab width
TabSize = 4
